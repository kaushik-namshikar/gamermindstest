{
  "apiVersion": 2,
  "name": "gm/regions",
  "title": "Players — Regions / Markets",
  "description": "4-column market region cards.",
  "category": "formatting",
  "keywords": ["regions", "markets", "languages"],
  "supports": { "align": ["full"], "html": false },
  "attributes": {
    "heading":        { "type": "string", "default": "Regions we focus on" },
    "subheading":     { "type": "string", "default": "Huge gaming markets often left out" },
    "region1Name":    { "type": "string", "default": "Latin America" },
    "region1Code":    { "type": "string", "default": "LATAM" },
    "region1Langs":   { "type": "string", "default": "PT-BR, ES-LATAM" },
    "region1Players": { "type": "string", "default": "120M+" },
    "region1Flag":    { "type": "string", "default": "🌎" },
    "region2Name":    { "type": "string", "default": "Southeast Asia" },
    "region2Code":    { "type": "string", "default": "SEA" },
    "region2Langs":   { "type": "string", "default": "TH, VI, ID, MS" },
    "region2Players": { "type": "string", "default": "95M+" },
    "region2Flag":    { "type": "string", "default": "🌏" },
    "region3Name":    { "type": "string", "default": "Eastern Europe" },
    "region3Code":    { "type": "string", "default": "EU-East" },
    "region3Langs":   { "type": "string", "default": "PL, RU, CZ, RO" },
    "region3Players": { "type": "string", "default": "85M+" },
    "region3Flag":    { "type": "string", "default": "🌍" },
    "region4Name":    { "type": "string", "default": "Middle East" },
    "region4Code":    { "type": "string", "default": "MENA" },
    "region4Langs":   { "type": "string", "default": "AR, TR, FA" },
    "region4Players": { "type": "string", "default": "70M+" },
    "region4Flag":    { "type": "string", "default": "🌍" }
  },
  "render": "file:./render.php"
}
