{
  "apiVersion": 2,
  "name": "gm/games-portfolio",
  "title": "Developers — Games Portfolio",
  "description": "Game cover grid driven by the Games CPT.",
  "category": "formatting",
  "keywords": ["portfolio", "games", "gallery"],
  "supports": { "align": ["full"], "html": false },
