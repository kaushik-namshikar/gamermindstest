{
  "apiVersion": 2,
  "name": "gm/quote-form",
  "title": "Developers — Quote Request Form",
  "description": "AJAX quote form for studios.",
  "category": "formatting",
  "keywords": ["form", "quote", "contact"],
  "supports": { "align": ["full"], "html": false },
  "attributes": {
    "heading":        { "type": "string", "default": "REQUEST A QUOTE" },
    "subheading":     { "type": "string", "default": "Share wordcount, languages, and deadline" },
    "disclaimer":     { "type": "string", "default": "We reply within 1–2 business days. NDAs welcome." },
    "submitText":     { "type": "string", "default": "Send Request" },
    "successMessage": { "type": "string", "default": "Thanks! We'll be in touch within 24 hours." },
    "toEmail":        { "type": "string", "default": "" }
  },
  "render": "file:./render.php"
}
