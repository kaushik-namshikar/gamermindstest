{
  "$schema": "https://schemas.wp.org/trunk/theme.json",
  "version": 2,
  "settings": {
    "color": {
      "palette": [
        {
          "slug": "gm-bg",
          "name": "Background",
          "color": "#050814"
        },
        {
          "slug": "gm-surface",
          "name": "Surface",
          "color": "#0B0E1A"
        },
        {
          "slug": "gm-text",
          "name": "Text",
          "color": "#F3F4FF"
        },
        {
          "slug": "gm-muted",
          "name": "Muted",
          "color": "rgba(243, 244, 255, 0.7)"
        },
        {
          "slug": "gm-primary",
          "name": "Primary",
          "color": "#4F46E5"
        },
        {
          "slug": "gm-primary-2",
          "name": "Primary 2",
          "color": "#60A5FA"
        },
        {
          "slug": "gm-accent",
          "name": "Accent",
          "color": "#F97316"
        },
        {
          "slug": "gm-accent-2",
          "name": "Accent 2",
          "color": "#F59E0B"
        },
        {
          "slug": "gm-purple",
          "name": "Purple",
          "color": "#8B5CF6"
        },
        {
          "slug": "gm-orange",
          "name": "Orange",
          "color": "#FB923C"
        }
      ],
      "gradients": [
        {
          "name": "Blue Glow",
          "gradient": "linear-gradient(135deg, rgba(79,70,229,0.44) 0%, rgba(96,165,250,0.24) 60%, rgba(0,0,0,0) 100%)"
        },
        {
          "name": "Warm Glow",
          "gradient": "linear-gradient(135deg, rgba(249,115,22,0.38) 0%, rgba(244,63,94,0.14) 60%, rgba(0,0,0,0) 100%)"
        }
      ]
    },
    "typography": {
      "fontFamilies": [
        {
          "fontFamily": "Inter, system-ui, -apple-system, BlinkMacSystemFont, \"Segoe UI\", sans-serif",
          "name": "Inter",
          "slug": "inter"
        }
      ],
      "fontSizes": [
        {
          "name": "Small",
          "slug": "sm",
          "size": "0.8125rem"
        },
        {
          "name": "Base",
          "slug": "md",
          "size": "1rem"
        },
        {
          "name": "Large",
          "slug": "lg",
          "size": "1.125rem"
        },
        {
          "name": "XL",
          "slug": "xl",
          "size": "1.5rem"
        },
        {
          "name": "2XL",
          "slug": "2xl",
          "size": "2rem"
        },
        {
          "name": "3XL",
          "slug": "3xl",
          "size": "2.5rem"
        },
        {
          "name": "4XL",
          "slug": "4xl",
          "size": "3rem"
        },
        {
          "name": "5XL",
          "slug": "5xl",
          "size": "3.75rem"
        }
      ],
      "textTransform": {
        "smallCaps": {
          "name": "Small Caps",
          "slug": "small-caps",
          "textTransform": "uppercase"
        }
      }
    },
    "spacing": {
      "units": ["px", "rem", "%"],
      "customPadding": true,
      "customMargin": true
    },
    "border": {
      "customRadius": true,
      "radius": [
        {
          "name": "Small",
          "slug": "sm",
          "size": "0.375rem"
        },
        {
          "name": "Default",
          "slug": "md",
          "size": "0.75rem"
        },
        {
          "name": "Large",
          "slug": "lg",
          "size": "1.5rem"
        },
        {
          "name": "Pill",
          "slug": "pill",
          "size": "9999px"
        }
      ]
    },
    "custom": {
      "gamerMinds": {
        "shadowGlow": "0 0 0 1px rgba(79, 70, 229, 0.35), 0 30px 60px rgba(79, 70, 229, 0.2)",
        "shadowElevated": "0 22px 54px rgba(0,0,0,0.55)",
        "easing": "cubic-bezier(0.16, 1, 0.3, 1)"
      }
    }
  },
  "styles": {
    "color": {
      "background": "var(--gm-bg)",
      "text": "var(--gm-text)"
    },
    "typography": {
      "fontFamily": "var(--gm-font)",
      "lineHeight": "1.55"
    }
  }
}
