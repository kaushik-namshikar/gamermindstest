{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 2,
  "name": "gm/trust-grid",
  "title": "Trust Grid",
  "description": "Grid of trust indicators, logos, or testimonials.",
  "category": "gm",
  "icon": "grid-view",
  "supports": {
    "html": false,
    "align": ["wide", "full"]
  },
  "attributes": {
    "title": {
      "type": "string",
      "source": "html",
      "selector": "h2",
      "default": "Trusted By"
    },
    "items": {
      "type": "array",
      "default": [
        {
          "logo": "🏆",
          "title": "Award Winner",
          "description": "Recognized for excellence in localization"
        },
        {
          "logo": "🌍",
          "title": "Global Reach",
          "description": "Supporting 50+ languages worldwide"
        },
        {
          "logo": "🎮",
          "title": "Gaming Experts",
          "description": "Specialized in game localization"
        }
      ]
    }
  },
  "editorScript": "file:./index.js",
  "editorStyle": "file:./editor.css",
  "style": "file:./style.css"
}